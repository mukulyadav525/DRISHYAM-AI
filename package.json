{
    "name": "drishyam-ai-workspace",
    "private": true,
    "scripts": {
        "build:dashboard": "npm run build -w dashboard",
        "build:simulation": "npm run build -w simulation-app",
        "build": "npm run build:dashboard && npm run build:simulation",
        "dev:backend": "cd backend && ./venv/bin/python3 -m uvicorn main:app --reload --port 8000",
        "dev:dashboard": "cd dashboard && npm run dev -- -p 3000",
        "dev:simulation": "cd simulation-app && npm run dev -- -p 3001",
        "dev:all": "npx concurrently \"npm run dev:backend\" \"npm run dev:dashboard\" \"npm run dev:simulation\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "workspaces": [
        "dashboard",
        "simulation-app"
    ]
}