\section{T2 --- Module 1: Fraud Risk Index Scoring}

\begin{tcolorbox}[infobox=saffron]
Module 1 is the gate. It decides in under 200ms whether a call is safe or suspicious.
If this is wrong, everything downstream is wrong.
\end{tcolorbox}

\begin{tcolorbox}[phasebox=saffron,
  title={T2A | Data Input Tests --- What Goes Into the Scorer}]
\begin{multicols}{2}
\begin{checklist2}
  \item[\textcolor{checkgreen}{\ding{51}}] API accepts phone number in E.164 format
  \item[\textcolor{checkgreen}{\ding{51}}] API accepts SIM age in days (integer)
  \item[\textcolor{checkgreen}{\ding{51}}] API accepts call velocity in last 24 hours
  \item[\textcolor{checkgreen}{\ding{51}}] API accepts CLI spoofed boolean flag
  \item[\textcolor{checkgreen}{\ding{51}}] API accepts prior complaint count
  \item[\textcolor{checkgreen}{\ding{51}}] API rejects missing required fields (returns 422)
  \item[\textcolor{checkgreen}{\ding{51}}] API rejects non-numeric SIM age (returns 400)
  \item[\textcolor{checkgreen}{\ding{51}}] API rejects phone numbers with wrong format
  \item[\textcolor{checkgreen}{\ding{51}}] API response time is under 200ms
  \item[\textcolor{checkgreen}{\ding{51}}] API returns JSON with fri\_score, risk, and action fields
\end{checklist2}
\end{multicols}
\end{tcolorbox}

\vspace{4pt}

\begin{tcolorbox}[phasebox=saffron,
  title={T2B | Scoring Logic Tests --- Are the Scores Correct?}]
\begin{multicols}{2}
\begin{checklist2}
  \item[\textcolor{checkgreen}{\ding{51}}] Normal 3-year-old SIM scores below 30
  \item[\textcolor{checkgreen}{\ding{51}}] Normal number with 3 calls today scores below 25
  \item[\textcolor{checkgreen}{\ding{51}}] Brand new SIM (2 days old) scores at least 40
  \item[\textcolor{checkgreen}{\ding{51}}] New SIM + 200 calls today scores above 85
  \item[\textcolor{checkgreen}{\ding{51}}] CLI spoofed flag adds at least 20 to base score
  \item[\textcolor{checkgreen}{\ding{51}}] Prior complaints field: 1 complaint adds at least 15
  \item[\textcolor{checkgreen}{\ding{51}}] Prior complaints field: 5+ complaints scores above 90
  \item[\textcolor{checkgreen}{\ding{51}}] Known blocked number in blocklist scores exactly 100
  \item[\textcolor{checkgreen}{\ding{51}}] Score never goes above 100 or below 0
  \item[\textcolor{checkgreen}{\ding{51}}] Festival surge multiplier is active during test date range
  \item[\textcolor{checkgreen}{\ding{51}}] Score above 85 triggers ROUTE\_TO\_HONEYPOT action
  \item[\textcolor{checkgreen}{\ding{51}}] Score 60--85 triggers FLAG + WARN action
  \item[\textcolor{checkgreen}{\ding{51}}] Score below 30 triggers ALLOW action
  \item[\textcolor{checkgreen}{\ding{51}}] Score exactly 85 triggers correct boundary action
  \item[\textcolor{checkgreen}{\ding{51}}] Geographic anomaly (call from abroad to India) adds to score
  \item[\textcolor{checkgreen}{\ding{51}}] SIM swap detected in last 48h adds at least 25 to score
  \item[\textcolor{checkgreen}{\ding{51}}] Score is fully logged with timestamp in PostgreSQL
  \item[\textcolor{checkgreen}{\ding{51}}] FRI score appears in Redis cache within 100ms of first call
  \item[\textcolor{checkgreen}{\ding{51}}] Second call to same number returns cached score faster
  \item[\textcolor{checkgreen}{\ding{51}}] Dashboard reflects FRI score within 5 seconds of scoring
\end{checklist2}
\end{multicols}

\passcriterion{All 20 scoring items pass. Normal numbers score LOW, suspicious numbers score HIGH, response time under 200ms every time.}
\failcriterion{Normal number scores above 50. Suspicious number scores below 70. Response time exceeds 500ms. Scores exceed 100 or go negative.}
\warncriterion{Festival surge multiplier test requires you to manually set the test date to a festive period in your config.}
\end{tcolorbox}

