\section{T3 --- Module 2: Agentic AI Honeypot Engine}

\begin{tcolorbox}[infobox=indblue]
This is the heart of Sentinel. The AI must be convincing enough that a professional scammer
does not realise they are talking to a machine. Test it yourself by playing the scammer.
\end{tcolorbox}

\begin{tcolorbox}[phasebox=indblue,
  title={T3A | Handoff Tests --- Does the Transfer Work?}]
\begin{multicols}{2}
\begin{checklist2}
  \item[\textcolor{checkgreen}{\ding{51}}] One-tap handoff button appears on citizen's phone screen
  \item[\textcolor{checkgreen}{\ding{51}}] Tapping button transfers call within 2 seconds
  \item[\textcolor{checkgreen}{\ding{51}}] Scammer hears no click, pause, or tone during transfer
  \item[\textcolor{checkgreen}{\ding{51}}] AI begins speaking within 1.5 seconds of transfer
  \item[\textcolor{checkgreen}{\ding{51}}] Citizen's phone shows ``AI is handling --- You are safe'' screen
  \item[\textcolor{checkgreen}{\ding{51}}] Citizen can monitor live call summary without hearing the call
  \item[\textcolor{checkgreen}{\ding{51}}] Citizen can tap ``Take Back'' to reclaim the call anytime
  \item[\textcolor{checkgreen}{\ding{51}}] Taking back restores call audio within 2 seconds
  \item[\textcolor{checkgreen}{\ding{51}}] If transfer fails, call falls back to citizen (no dropped call)
  \item[\textcolor{checkgreen}{\ding{51}}] Transfer works over both 4G and Wi-Fi
\end{checklist2}
\end{multicols}
\end{tcolorbox}

\vspace{4pt}

\begin{tcolorbox}[phasebox=indblue,
  title={T3B | Persona Tests --- Is the AI Believable?}]
\begin{multicols}{2}
\begin{checklist2}
  \item[\textcolor{checkgreen}{\ding{51}}] Elderly uncle persona speaks slow, uses filler words (``acha\ldots'', ``ek second'')
  \item[\textcolor{checkgreen}{\ding{51}}] Rural farmer persona uses regional vocabulary correctly
  \item[\textcolor{checkgreen}{\ding{51}}] College student persona speaks faster, uses casual language
  \item[\textcolor{checkgreen}{\ding{51}}] Housewife persona uses domestic context naturally
  \item[\textcolor{checkgreen}{\ding{51}}] Executive persona is businesslike, uses English-Hindi mix
  \item[\textcolor{checkgreen}{\ding{51}}] AI never says ``I am an AI'' or ``artificial intelligence''
  \item[\textcolor{checkgreen}{\ding{51}}] AI never says ``as a language model'' or similar phrases
  \item[\textcolor{checkgreen}{\ding{51}}] AI correctly uses first name of chosen persona throughout
  \item[\textcolor{checkgreen}{\ding{51}}] AI adapts tone when scammer shifts language (Hindi to English)
  \item[\textcolor{checkgreen}{\ding{51}}] AI handles being asked to repeat something naturally
  \item[\textcolor{checkgreen}{\ding{51}}] AI handles background noise and partial hearing naturally
  \item[\textcolor{checkgreen}{\ding{51}}] AI persona stays consistent over at least 5 minutes
  \item[\textcolor{checkgreen}{\ding{51}}] Two identical scam scripts get different AI responses each time
  \item[\textcolor{checkgreen}{\ding{51}}] AI does not reveal system information when directly asked
  \item[\textcolor{checkgreen}{\ding{51}}] AI does not hallucinate false personal details that break persona
\end{checklist2}
\end{multicols}
\end{tcolorbox}

\vspace{4pt}

\begin{tcolorbox}[phasebox=indblue,
  title={T3C | Intelligence Extraction Tests --- Does It Collect Evidence?}]
\begin{multicols}{2}
\begin{checklist2}
  \item[\textcolor{checkgreen}{\ding{51}}] NER extracts phone number spoken by scammer within 60 seconds
  \item[\textcolor{checkgreen}{\ding{51}}] NER extracts UPI ID spoken by scammer
  \item[\textcolor{checkgreen}{\ding{51}}] NER extracts fake organisation name
  \item[\textcolor{checkgreen}{\ding{51}}] NER extracts scammer's self-given name/alias
  \item[\textcolor{checkgreen}{\ding{51}}] NER extracts bank name targeted
  \item[\textcolor{checkgreen}{\ding{51}}] All extracted entities appear in dashboard within 30 seconds
  \item[\textcolor{checkgreen}{\ding{51}}] Confession trap activates when scammer applies maximum pressure
  \item[\textcolor{checkgreen}{\ding{51}}] Scammer fatigue index increases over a 5-minute call
  \item[\textcolor{checkgreen}{\ding{51}}] Call transcript saved in full and searchable after call
  \item[\textcolor{checkgreen}{\ding{51}}] Voice fingerprint generated and stored after call ends
\end{checklist2}
\end{multicols}

\passcriterion{Handoff seamless in under 2 seconds. AI holds character for 5+ minutes. At least 3 entities extracted per 5-minute call. Transcript saved.}
\failcriterion{AI breaks character, mentions it is AI, drops call during transfer, or extracts zero entities after 3 minutes.}
\end{tcolorbox}

